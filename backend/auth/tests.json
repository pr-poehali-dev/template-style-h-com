{
  "tests": [
    {
      "name": "Register user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "Тест Юзер", "email": "test_volna_reg@example.com", "password": "password123", "handle": "test_volna_reg"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_volna_reg@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login correct",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_volna_reg@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
